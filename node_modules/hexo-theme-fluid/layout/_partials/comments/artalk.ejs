<% if (theme.artalk) { %>
  <div id="artalk"></div>
  <script>
    Fluid.utils.loadComments('#artalk', function() {
      Fluid.utils.createCssLink('/dist/Artalk.css')
      Fluid.utils.createScript('/dist/Artalk.js', function() {
        var opts = <%- JSON.stringify(theme.artalk || {}) %>;
        delete opts.server;
        var options = Object.assign(opts, {
          el: '#artalk',
          pageKey: '<%= page.path %>',
          pageTitle: '<%= page.title %>'
        })
        Artalk.init(options);
        Fluid.utils.waitElementVisible('#artalk .atk-comment', function() {
          var imgSelector = '#artalk .atk-comment img:not(.atk-emoji)';
          Fluid.plugins.imageCaption(imgSelector);
          Fluid.plugins.fancyBox(imgSelector);
        })
      });
    });
  </script>
  <noscript>Please enable JavaScript to view the comments</noscript>
<% } %>
