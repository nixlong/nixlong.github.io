<%
page.layout = "page"
page.title = page.title || "归档"
%>

<div class="list-group">
  <p class="h4">共 <%= site.posts.length %> 篇文章</p>
  <hr>
  <% var yearCursor, quarterCursor %>
  <% site.posts.sort('date', -1).each(function (post) { %>
    <% var y = date(post.date, "YYYY") %>
    <% var m = parseInt(date(post.date, "M")) %>
    <% var q = "Q" + Math.ceil(m / 3) %>
    <% if (y !== yearCursor) { %>
      <% yearCursor = y; quarterCursor = null %>
      <p class="h5"><%= y %> 年</p>
    <% } %>
    <% if (q !== quarterCursor) { %>
      <% quarterCursor = q %>
      <p class="h6 text-muted ml-2"><%= q %></p>
    <% } %>
    <a href="<%= url_for(post.path) %>" class="list-group-item list-group-item-action">
      <time><%= date(post.date, "MM-DD") %></time>
      <div class="list-group-item-title"><%= post.title %></div>
    </a>
  <% }) %>
</div>
